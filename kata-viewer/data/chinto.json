{
  "name": "Chinto",
  "style": "Isshin Ryu",
  "displayName": "Chinto (鎮東)",
  "steps": [
    { "id": 0, "label": "Ready — musubi to heiko", "coachCall": "Ready position.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 0, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "feetTogether", "arms": ["armsDown"] },
        { "t": 0.4, "stance": "bow" },
        { "t": 1, "stance": "ready" }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "Chinto.md step 0" } },
    { "id": 1, "label": "45° left — cat stance, X-guard", "coachCall": "Look left. Cat stance. Cross guard.", "beats": 2, "kiai": false,
      "embusen": { "x": 0, "z": 0, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "ready", "overrides": { "head": { "y": 0.6 } } },
        { "t": 1, "stance": "catR", "arms": ["xGuardChest"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 0.9, "z": 0.9, "facing": 3.927 }, "text": "Cover against the incoming strike and angle off the line." },
      "transition": { "known": true, "source": "Chinto.md step 1" } },
    { "id": 2, "label": "Step in — open block, hammerfist to palm, seize", "coachCall": "Step in. Open block. Hammerfist. Seize the arm.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.4, "z": 0.4, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "chintoL", "arms": ["openHandBlockL", "chamberR"] },
        { "t": 0.4, "stance": "chintoL", "arms": ["openHandBlockL", "hammerfistR"] },
        { "t": 1, "stance": "chintoL", "arms": ["reinforcedBlockR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 1.3, "z": 1.3, "facing": 3.927 }, "text": "Parry and crash in, check the arm, seize for control — arm bar setup." },
      "transition": { "known": true, "source": "Chinto.md step 2" } },
    { "id": 3, "label": "Right steps back — reinforced pull", "coachCall": "Step back. Pull and reinforce.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.25, "z": 0.25, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "chintoL", "arms": ["reinforcedBlockR"] },
        { "t": 1, "stance": "catL", "arms": ["reinforcedBlockR"], "overrides": { "spine": { "x": 0.15 } } }
      ],
      "bunkai": { "known": true, "attack": "grabWristR", "attackerFrom": { "x": 1.1, "z": 1.1, "facing": 3.927 }, "text": "Pull the opponent off balance; arm break or throw preparation." },
      "transition": { "known": true, "source": "Chinto.md step 3" } },
    { "id": 4, "label": "Pivot front — punch", "coachCall": "Pivot front. Punch.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.25, "z": 0.25, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardChestL", "chamberR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["guardChestL", "punchMidR"] }
      ],
      "bunkai": { "known": true, "attack": "none", "attackerFrom": { "x": 0.25, "z": 1.4, "facing": 3.1416 }, "text": "Strike as the opponent is pulled off line." },
      "transition": { "known": true, "source": "Chinto.md step 4" } },
    { "id": 5, "label": "Shuffle — second punch", "coachCall": "Shuffle. Punch.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.25, "z": 0.65, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardChestR", "chamberL"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["guardChestR", "punchMidL"] }
      ],
      "bunkai": { "known": true, "attack": "none", "attackerFrom": { "x": 0.25, "z": 1.8, "facing": 3.1416 }, "text": "Follow-up finishing blow across the centerline." },
      "transition": { "known": true, "source": "Chinto.md step 5" } },
    { "id": 6, "label": "Open to Seiunchin — low block", "coachCall": "Open the stance. Low block.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.25, "z": 0.65, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowR", "chamberL"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": 0.25, "z": 1.8, "facing": 3.1416 }, "text": "Drop the level and defend the low attack." },
      "transition": { "known": true, "source": "Chinto.md step 6" } },
    { "id": 7, "label": "Pivot to oblique — open-hand block", "coachCall": "Angle right. Open block.", "beats": 2, "kiai": false,
      "embusen": { "x": -0.1, "z": 1.0, "facing": -0.7854 },
      "keyframes": [
        { "t": 0, "stance": "chintoR", "arms": ["guardBoth"] },
        { "t": 1, "stance": "chintoR", "arms": ["openHandBlockR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": -1.0, "z": 1.9, "facing": 2.3562 }, "text": "Angle entry against a new attacker on the diagonal." },
      "transition": { "known": true, "source": "Chinto.md step 7" } },
    { "id": 8, "label": "Hammerfist to palm — wrap the arm", "coachCall": "Hammerfist. Wrap the arm.", "beats": 3, "kiai": false,
      "embusen": { "x": -0.1, "z": 1.0, "facing": -0.7854 },
      "keyframes": [
        { "t": 0, "stance": "chintoR", "arms": ["openHandBlockL", "chamberR"] },
        { "t": 0.5, "stance": "chintoR", "arms": ["openHandBlockL", "hammerfistR"] },
        { "t": 1, "stance": "chintoR", "arms": ["reinforcedBlockR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": -1.0, "z": 1.9, "facing": 2.3562 }, "text": "Re-establish arm control and striking — same structure as step 2." },
      "transition": { "known": true, "source": "Chinto.md step 8" } },
    { "id": 9, "label": "Step back on the oblique — reinforced lock", "coachCall": "Step back. Lock the arm.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.05, "z": 0.85, "facing": -0.7854 },
      "keyframes": [
        { "t": 0, "stance": "chintoR", "arms": ["reinforcedBlockR"] },
        { "t": 1, "stance": "catR", "arms": ["reinforcedBlockR"], "overrides": { "spine": { "x": 0.15 } } }
      ],
      "bunkai": { "known": true, "attack": "grabWristR", "attackerFrom": { "x": -0.9, "z": 1.8, "facing": 2.3562 }, "text": "Pulling, locking motion on the opponent's arm — arm bar or shoulder lock." },
      "transition": { "known": true, "source": "Chinto.md step 9" } },
    { "id": 10, "label": "Pivot front — punch", "coachCall": "Pivot front. Punch.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.05, "z": 0.85, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["guardChestL", "chamberR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardChestL", "punchMidR"] }
      ],
      "bunkai": { "known": true, "attack": "none", "attackerFrom": { "x": 0.05, "z": 2.0, "facing": 3.1416 }, "text": "Finish against the off-balanced opponent." },
      "transition": { "known": true, "source": "Chinto.md step 10" } },
    { "id": 11, "label": "Shuffle — second punch", "coachCall": "Shuffle. Punch.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.05, "z": 1.25, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["guardChestR", "chamberL"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardChestR", "punchMidL"] }
      ],
      "bunkai": { "known": true, "attack": "none", "attackerFrom": { "x": 0.05, "z": 2.4, "facing": 3.1416 }, "text": "Additional finishing blow." },
      "transition": { "known": true, "source": "Chinto.md step 11" } },
    { "id": 12, "label": "Drop low — leg check block", "coachCall": "Drop. Low block.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.05, "z": 1.25, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowL", "guardChestR"] }
      ],
      "bunkai": { "known": true, "attack": "sweepLow", "attackerFrom": { "x": 0.05, "z": 2.4, "facing": 3.1416 }, "text": "Defend the sweep or low attack; loads the jump." },
      "transition": { "known": true, "source": "Chinto.md step 12" } },
    { "id": 13, "label": "Block, jump front kick, land in low X-block", "coachCall": "Block. Jump kick! Land. X block.", "beats": 5, "kiai": false,
      "embusen": { "x": 0.05, "z": 1.6, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "catL", "arms": ["blockMidL", "guardChestR"] },
        { "t": 0.35, "stance": "ready", "arms": ["guardBoth"], "legs": ["jumpKickR"] },
        { "t": 0.65, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["xBlockLow"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 0.05, "z": 2.9, "facing": 3.1416 }, "text": "Defend the punch, nidan-geri jump kick, land covering the low line." },
      "transition": { "known": true, "source": "Chinto.md step 13; jump mechanics per isshinryukarate.net (nidan geri, land Seisan left forward, right-over-left low X-block)" } },
    { "id": 14, "label": "Turn — repeat X-block", "coachCall": "Turn. X block.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.05, "z": 1.6, "facing": 1.5708 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["xBlockLow"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": 1.2, "z": 1.6, "facing": 4.7124 }, "text": "Deal with a kick from a new direction." },
      "transition": { "known": false, "source": "Chinto.md step 14 — exact turn amount varies by lineage; UNVERIFIED" } },
    { "id": 15, "label": "Step around — punches into fighting posture", "coachCall": "Step around. Punch. Punch. Elbow. Guard.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.05, "z": 1.9, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["punchMidL", "chamberR"] },
        { "t": 0.35, "stance": "seisanDachiL", "arms": ["punchMidR", "guardChestL"] },
        { "t": 0.65, "stance": "seisanDachiL", "arms": ["elbowStrikeL", "guardChestR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["guardBoth"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 1.1, "z": 3.0, "facing": 3.927 }, "text": "Punch combination finishing in fighting guard." },
      "transition": { "known": true, "source": "Chinto.md step 15" } },
    { "id": 16, "label": "Step back — strike with cover", "coachCall": "Step back. Strike. Cover.", "beats": 2, "kiai": false,
      "embusen": { "x": -0.1, "z": 1.75, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "catL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "catL", "arms": ["punchMidR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": 0.8, "z": 2.65, "facing": 3.927 }, "text": "Retreat with a short-power counter strike and guard." },
      "transition": { "known": true, "source": "Chinto.md step 16" } },
    { "id": 17, "label": "Step in — throat, solar plexus, collarbone strikes", "coachCall": "Step in. Throat. Body. Collarbone.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.15, "z": 2.0, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 0.3, "stance": "seisanDachiL", "arms": ["nukiteR", "guardChestL"] },
        { "t": 0.6, "stance": "seisanDachiL", "arms": ["punchMidL", "guardChestR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["shutoMidR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 1.0, "z": 2.9, "facing": 3.927 }, "text": "High/low combination: throat, solar plexus, then collarbone." },
      "transition": { "known": true, "source": "Chinto.md step 17" } },
    { "id": 18, "label": "Turn — block, double fists down", "coachCall": "Turn. Block. Double fists down.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.15, "z": 2.0, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["blockMidR", "guardChestL"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["doubleFistDown"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": -0.8, "z": 1.1, "facing": 0.7854 }, "text": "Clear the arm and strike down onto arms or ribs." },
      "transition": { "known": true, "source": "Chinto.md step 18" } },
    { "id": 19, "label": "Open block, strike arm, grab hair, smash to leg", "coachCall": "Block. Strike the arm. Grab. Smash down.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.15, "z": 2.0, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["openHandBlockR", "guardChestL"] },
        { "t": 0.35, "stance": "seisanDachiR", "arms": ["hammerfistL", "guardChestR"] },
        { "t": 0.65, "stance": "seisanDachiR", "arms": ["grabPullR", "grabPullL"], "overrides": { "spine": { "x": 0.3 } } },
        { "t": 1, "stance": "seisanDachiR", "arms": ["grabPullR", "grabPullL"], "legs": ["kneeLiftR"], "overrides": { "spine": { "x": 0.35 } } }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": -0.8, "z": 1.1, "facing": 0.7854 }, "text": "Arm destruction, head control, drag down onto the knee — a takedown." },
      "transition": { "known": true, "source": "Chinto.md step 19" } },
    { "id": 20, "label": "T-stance guard — block kick, cover", "coachCall": "T-stance. Guard the kick.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.3, "z": 1.85, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "tStanceR", "arms": ["guardBoth"] },
        { "t": 1, "stance": "tStanceR", "arms": ["blockLowR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": -0.6, "z": 0.95, "facing": 0.7854 }, "text": "Side-on defense against kick and body shot." },
      "transition": { "known": true, "source": "Chinto.md step 20" } },
    { "id": 21, "label": "Front kick — land, double low block", "coachCall": "Front kick. Land. Double low block.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.15, "z": 1.7, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "tStanceR", "arms": ["guardBoth"], "legs": ["frontKickR"] },
        { "t": 0.5, "stance": "seisanDachiR", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["blockDoubleLow"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickL", "attackerFrom": { "x": -0.7, "z": 0.85, "facing": 0.7854 }, "text": "Stop the advance with a kick, then shield the groin line." },
      "transition": { "known": true, "source": "Chinto.md step 21" } },
    { "id": 22, "label": "Twist to T-stance — right hand front", "coachCall": "Twist. Guard front.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.15, "z": 1.7, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "tStanceR", "arms": ["guardBoth"] },
        { "t": 1, "stance": "tStanceR", "arms": ["openHandBlockR", "guardChestL"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "Chinto.md step 22" } },
    { "id": 23, "label": "Step in — leg block and head block, twice", "coachCall": "Step in. Leg block, head block. Again.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.45, "z": 2.0, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "chintoL", "arms": ["blockHighL"], "legs": ["legLiftL"] },
        { "t": 0.5, "stance": "chintoL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "chintoR", "arms": ["blockHighR"], "legs": ["legLiftR"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": 1.4, "z": 2.9, "facing": 3.927 }, "text": "Advance under layered kicking and punching attack." },
      "transition": { "known": true, "source": "Chinto.md step 23" } },
    { "id": 24, "label": "Spin — drop into leg block", "coachCall": "Spin. Drop. Leg block.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.3, "z": 1.85, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "ready", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowL", "guardChestR"], "legs": [] }
      ],
      "bunkai": { "known": true, "attack": "sweepLow", "attackerFrom": { "x": -0.6, "z": 0.95, "facing": 0.7854 }, "text": "Turn to the new attacker and stop the low attack." },
      "transition": { "known": true, "source": "Chinto.md step 24" } },
    { "id": 25, "label": "Step across and behind — double collarbone strike", "coachCall": "Step across. Double strike to the collarbones.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.55, "z": 1.6, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "crossoverL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["doubleCollarbone"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": -0.3, "z": 0.7, "facing": 0.7854 }, "text": "Attack both sides of the neck and collarbone." },
      "transition": { "known": true, "source": "Chinto.md step 25" } },
    { "id": 26, "label": "Step in — elbow shields the groin", "coachCall": "Step in. Elbow down.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.4, "z": 1.45, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["elbowStrikeR", "guardChestL"], "overrides": { "spine": { "x": 0.2 } } }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": -0.5, "z": 0.55, "facing": 0.7854 }, "text": "Close-shut defense: elbow shields or strikes against the low kick." },
      "transition": { "known": true, "source": "Chinto.md step 26" } },
    { "id": 27, "label": "Twist to T-stance — reset guard", "coachCall": "Twist. Reset guard.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.4, "z": 1.45, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "tStanceR", "arms": ["guardBoth"] },
        { "t": 1, "stance": "tStanceR", "arms": ["openHandBlockR", "guardChestL"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "Chinto.md step 27" } },
    { "id": 28, "label": "Set Seisan — front kick, C-step punch", "coachCall": "Set. Front kick. C-step. Punch.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.7, "z": 1.75, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 0.35, "stance": "seisanDachiL", "arms": ["guardBoth"], "legs": ["frontKickR"] },
        { "t": 0.7, "stance": "seisanDachiR", "arms": ["guardChestL", "chamberR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardChestL", "punchMidR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 1.6, "z": 2.65, "facing": 3.927 }, "text": "Enter with the kick, angle with the C-step, punch." },
      "transition": { "known": true, "source": "Chinto.md step 28" } },
    { "id": 29, "label": "Rear grab escape — double kidney strike", "coachCall": "Grabbed! Step. Strike the kidneys.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.7, "z": 1.75, "facing": 2.3562 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 0.5, "stance": "seisanDachiL", "arms": ["doubleKidneyStrike"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["doubleKidneyStrike"] }
      ],
      "bunkai": { "known": true, "attack": "grabRear", "attackerFrom": { "x": 1.2, "z": 1.25, "facing": 2.3562 }, "text": "Escape the rear grab, step behind, double strikes to the kidneys — classic Chinto image." },
      "transition": { "known": true, "source": "Chinto.md step 29" } },
    { "id": 30, "label": "T-stance — block, cover, KIAI kick", "coachCall": "Guard. Cover. Kiai kick!", "beats": 4, "kiai": true,
      "embusen": { "x": 0.55, "z": 1.6, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "tStanceR", "arms": ["guardBoth"] },
        { "t": 0.4, "stance": "tStanceR", "arms": ["blockMidR", "guardChestL"] },
        { "t": 0.75, "stance": "tStanceR", "arms": ["guardBoth"], "legs": ["frontKickR"] },
