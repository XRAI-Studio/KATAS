      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["blockLowL", "chamberR"] },
        { "t": 0.6, "stance": "seisanDachiL", "arms": ["blockLowL", "punchMidR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["blockLowL", "chamberR"] }
      ],
