      "keyframes": [
        { "t": 0, "stance": "feetTogether", "arms": ["guardBoth"] },
        { "t": 0.4, "stance": "seisanDachiL", "arms": ["punchMidL", "guardChestR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["punchMidR", "guardChestL"], "overrides": { "chest": { "y": -0.35 } } }
