        { "t": 0, "stance": "feetTogether", "arms": ["guardBoth"] },
        { "t": 0.4, "stance": "seisanDachiR", "arms": ["punchMidR", "guardChestL"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["punchMidL", "guardChestR"], "overrides": { "chest": { "y": 0.35 } } }
