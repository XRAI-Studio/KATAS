      "transition": { "known": true, "source": "wansu.md step 10" } },
    { "id": 11, "label": "Stack the hands — set up the dump", "coachCall": "Stack the hands. Take hold.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.4, "z": 2.0, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["handsStacked"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0.4, "z": 3.0, "facing": 3.1416 }, "text": "Grabbing and head-control setup — the signature Wansu moment." },
      "transition": { "known": true, "source": "wansu.md step 11" } },
    { "id": 12, "label": "The Wansu dump — KIAI", "coachCall": "Load. Dump! Kiai!", "beats": 4, "kiai": true,
      "embusen": { "x": 0.4, "z": 2.0, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["dumpLoad"] },
        { "t": 0.5, "stance": "seiunchinDachi", "arms": ["dumpLoad"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["dumpFinish"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0.4, "z": 2.9, "facing": 3.1416 }, "text": "Kata garuma: grab high at the throat, hook low, lift and dump the attacker during the 180° pivot." },
      "transition": { "known": true, "source": "wansu.md step 12; mechanics per isshinryukarate.net and isshin-concentration.blogspot.com; kiai on the dump" } },
