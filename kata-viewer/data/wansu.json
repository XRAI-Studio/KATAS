      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["guardChestL", "chamberR"], "overrides": { "head": { "y": 0.7 } } },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardBoth"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "wansu.md step 13" } },
    { "id": 14, "label": "Left side — open block, punch, knee", "coachCall": "Step left. Open block. Punch. Knee.", "beats": 4, "kiai": false,
      "embusen": { "x": -0.2, "z": 1.8, "facing": 4.7124 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["openHandBlockL", "chamberR"] },
        { "t": 0.4, "stance": "seisanDachiL", "arms": ["openHandBlockL", "punchMidR"] },
        { "t": 0.7, "stance": "seisanDachiL", "arms": ["guardBoth"], "legs": ["kneeLiftR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["punchMidR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": -1.4, "z": 1.8, "facing": 1.5708 }, "text": "Side entry with block, punch, and knee strike." },
      "transition": { "known": true, "source": "wansu.md step 14" } },
    { "id": 15, "label": "Right side — mirror block, punch, knee", "coachCall": "Step right. Open block. Punch. Knee.", "beats": 4, "kiai": false,
      "embusen": { "x": 1.0, "z": 1.8, "facing": 1.5708 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["openHandBlockR", "chamberL"] },
        { "t": 0.4, "stance": "seisanDachiR", "arms": ["openHandBlockR", "punchMidL"] },
        { "t": 0.7, "stance": "seisanDachiR", "arms": ["guardBoth"], "legs": ["kneeLiftL"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["punchMidL", "guardChestR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": 2.2, "z": 1.8, "facing": 4.7124 }, "text": "Mirror of step 14 on the opposite side." },
      "transition": { "known": true, "source": "wansu.md step 15" } },
    { "id": 16, "label": "Step out — evade, face punch, angle punch", "coachCall": "Step up. Slip. Punch. Angle punch.", "beats": 4, "kiai": false,
      "embusen": { "x": 0.4, "z": 1.6, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "feetTogether", "arms": ["guardBoth"] },
        { "t": 0.4, "stance": "seisanDachiR", "arms": ["punchHighR", "guardChestL"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["punchMidL", "guardChestR"], "overrides": { "chest": { "y": 0.35 } } }
