      "transition": { "known": true, "source": "wansu.md step 16 (file truncates during step 17)" } },
    { "id": 17, "label": "Left side blade kick with catch (reconstructed)", "coachCall": "Side kick. Catch.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.4, "z": 1.4, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "ready", "arms": ["guardBoth"] },
        { "t": 0.5, "stance": "ready", "arms": ["grabPullL", "guardChestR"], "legs": ["sideKickL"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["guardBoth"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": false, "source": "Reconstructed from MIT Isshinryu Club + isshinryukarate.net; linking footwork from step 16 is UNVERIFIED" } },
    { "id": 18, "label": "Right side blade kick with catch (reconstructed)", "coachCall": "Side kick. Catch.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.4, "z": 1.2, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "ready", "arms": ["guardBoth"] },
        { "t": 0.5, "stance": "ready", "arms": ["grabPullR", "guardChestL"], "legs": ["sideKickR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardBoth"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": false, "source": "Reconstructed; sequence order between sources differs — UNVERIFIED" } },
