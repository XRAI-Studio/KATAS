      "embusen": { "x": 0.4, "z": 0.9, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 0.6, "stance": "seisanDachiL", "arms": ["openHandBlockL", "openHandBlockR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["guardChestL", "elbowStrikeR"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0.4, "z": -0.1, "facing": 0 }, "text": "Slow deploying guard, then elbow smash to the temple." },
      "transition": { "known": true, "source": "MIT Isshinryu Club Wansu description" } },
    { "id": 20, "label": "Cat stance — front kick (reconstructed)", "coachCall": "Cat stance. Front kick.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.4, "z": 0.7, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "catL", "arms": ["guardBoth"] },
        { "t": 0.55, "stance": "catL", "arms": ["guardBoth"], "legs": ["frontKickL"] },
        { "t": 1, "stance": "catL", "arms": ["guardBoth"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 0.4, "z": -0.3, "facing": 0 }, "text": "Stop the advance with a straight kick from light cat stance." },
      "transition": { "known": true, "source": "MIT Isshinryu Club Wansu description" } },
