      "embusen": { "x": 0.4, "z": 0.5, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "catR", "arms": ["guardBoth"] },
        { "t": 0.55, "stance": "catR", "arms": ["guardBoth"], "legs": ["frontKickR"] },
        { "t": 1, "stance": "catR", "arms": ["guardBoth"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": 0.4, "z": -0.5, "facing": 0 }, "text": "Second stopping kick from the other side." },
      "transition": { "known": true, "source": "MIT Isshinryu Club Wansu description" } },
    { "id": 22, "label": "Double shuto to the throat — KIAI (reconstructed)", "coachCall": "Double shuto. Kiai!", "beats": 3, "kiai": true,
      "embusen": { "x": 0.4, "z": 0.3, "facing": 3.1416 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["guardBoth"] },
        { "t": 0.55, "stance": "seisanDachiR", "arms": ["doubleShutoThroat"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["doubleShutoThroat"] }
      ],
      "bunkai": { "known": true, "attack": "chokeFront", "attackerFrom": { "x": 0.4, "z": -0.7, "facing": 0 }, "text": "Double shuto to both sides of the throat — the closing kiai strike." },
      "transition": { "known": true, "source": "MIT Isshinryu Club: 'double shuto to throat to either side & kiai'" } },
    { "id": 23, "label": "Slow guard — return and bow (reconstructed)", "coachCall": "Guard... return. Bow.", "beats": 4, "kiai": false,
      "embusen": { "x": 0, "z": 0, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["openHandBlockL", "openHandBlockR"] },
        { "t": 0.5, "stance": "feetTogether", "arms": ["armsDown"] },
        { "t": 1, "stance": "bow" }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "MIT Isshinryu Club Wansu description" } }
  ]
