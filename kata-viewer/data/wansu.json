      "embusen": { "x": 0.4, "z": 1.8, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "ready", "arms": ["guardBoth"], "legs": ["frontKickR"] },
        { "t": 0.45, "stance": "seisanDachiR", "arms": ["guardBoth"] },
        { "t": 0.75, "stance": "ready", "arms": ["guardBoth"], "legs": ["frontKickL"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["guardBoth"] }
      ],
