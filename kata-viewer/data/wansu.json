      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["blockLowL", "chamberR"] },
        { "t": 0.6, "stance": "seisanDachiL", "arms": ["blockLowL", "punchMidR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["blockLowL", "chamberR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 2.1, "z": 1.5, "facing": 4.7124 }, "text": "New attacker on the left line — mirror of step 2." },
      "transition": { "known": true, "source": "wansu.md step 5" } },
    { "id": 6, "label": "Step in — side block, finger thrust (mirror)", "coachCall": "Step. Open block. Finger thrust.", "beats": 3, "kiai": false,
      "embusen": { "x": 1.5, "z": 1.5, "facing": 1.5708 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["openHandBlockR", "chamberL"] },
        { "t": 0.55, "stance": "seisanDachiR", "arms": ["openHandBlockR", "nukiteL"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardChestR", "nukiteL"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 2.7, "z": 1.5, "facing": 4.7124 }, "text": "Mirror of step 3: nukite into a soft target." },
      "transition": { "known": true, "source": "wansu.md step 6" } },
    { "id": 7, "label": "Step behind — angle punch with pull (mirror)", "coachCall": "Step behind. Pull. Punch.", "beats": 3, "kiai": false,
      "embusen": { "x": 1.2, "z": 1.3, "facing": 0.9 },
      "keyframes": [
        { "t": 0, "stance": "crossoverL", "arms": ["guardBoth"] },
        { "t": 0.6, "stance": "seisanDachiL", "arms": ["grabPullR", "punchMidL"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["grabPullR", "punchMidL"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": 2.1, "z": 2.2, "facing": 4.0416 }, "text": "Symmetrical off-line entry and counter." },
      "transition": { "known": true, "source": "wansu.md step 7" } },
    { "id": 8, "label": "Front — evade, punch, angle punch", "coachCall": "Face front. Slip. Punch. Angle punch.", "beats": 4, "kiai": false,
