{
  "name": "Wansu",
  "style": "Isshin Ryu",
  "displayName": "Wansu (汪楫)",
  "steps": [
    { "id": 0, "label": "Ready — look left, guard set", "coachCall": "Ready. Look left.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 0, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "feetTogether", "arms": ["armsDown"] },
        { "t": 0.4, "stance": "bow" },
        { "t": 1, "stance": "ready", "arms": ["handsStacked"], "overrides": { "head": { "y": 0.8 } } }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "wansu.md step 0" } },
    { "id": 1, "label": "45° left — low block, punch", "coachCall": "Angle left. Low block. Punch.", "beats": 3, "kiai": false,
