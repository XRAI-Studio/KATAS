        { "t": 0.55, "stance": "seisanDachiR", "arms": ["openHandBlockL", "nukiteR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["guardChestL", "nukiteR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": 0.3, "z": 2.9, "facing": 3.1416 }, "text": "Deflect in, thrust to a soft target — solar plexus, neck, or groin." },
      "transition": { "known": true, "source": "wansu.md step 3" } },
    { "id": 4, "label": "Step behind — angle punch with pull", "coachCall": "Step behind. Pull. Punch.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.0, "z": 1.5, "facing": -0.6 },
      "keyframes": [
        { "t": 0, "stance": "crossoverR", "arms": ["guardBoth"] },
        { "t": 0.6, "stance": "seisanDachiR", "arms": ["grabPullL", "punchMidR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["grabPullL", "punchMidR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": -0.7, "z": 2.4, "facing": 2.5416 }, "text": "Off-line entry with hikite pull into a strong counter." },
      "transition": { "known": true, "source": "wansu.md step 4" } },
    { "id": 5, "label": "Left line — low block, punch", "coachCall": "Look left. Step. Low block. Punch.", "beats": 3, "kiai": false,
