{
  "name": "Seiunchin",
  "style": "Isshin Ryu",
  "displayName": "Seiunchin (制引戦)",
  "steps": [
    { "id": 0, "label": "Ready — bow and set", "coachCall": "Ready position. Bow.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 0, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "feetTogether", "arms": ["armsDown"] },
        { "t": 0.4, "stance": "bow" },
        { "t": 1, "stance": "ready" }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "Seiunchin.md" } },
    { "id": 1, "label": "Slide right forward — break grab, low blocks, haito, nukite", "coachCall": "Slide in. Break the grab. Double low block. Haito. Pull and nukite.", "beats": 5, "kiai": false,
      "embusen": { "x": 0, "z": 0.5, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["openHandBlockL", "openHandBlockR"] },
        { "t": 0.3, "stance": "seiunchinDachi", "arms": ["blockDoubleLow"] },
        { "t": 0.6, "stance": "seiunchinDachi", "arms": ["haitoR", "guardChestL"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["grabPullR", "nukiteL"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0, "z": 1.6, "facing": 3.1416 }, "text": "Break the grab, defend low kicks, counter-thrust to throat or solar plexus." },
      "transition": { "known": true, "source": "Seiunchin.md step 1" } },
    { "id": 2, "label": "Slide left forward — mirror sequence", "coachCall": "Look right. Slide in. Double low block. Haito. Pull and nukite.", "beats": 5, "kiai": false,
      "embusen": { "x": 0, "z": 1.0, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["openHandBlockL", "openHandBlockR"], "overrides": { "head": { "y": -0.7 } } },
        { "t": 0.3, "stance": "seiunchinDachi", "arms": ["blockDoubleLow"] },
        { "t": 0.6, "stance": "seiunchinDachi", "arms": ["haitoL", "guardChestR"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["grabPullL", "nukiteR"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0, "z": 2.1, "facing": 3.1416 }, "text": "Mirror application against a second attacker." },
      "transition": { "known": true, "source": "Seiunchin.md step 2" } },
    { "id": 3, "label": "Slide right forward — third repeat", "coachCall": "Look rear. Slide in. Double low block. Haito. Pull and nukite.", "beats": 5, "kiai": false,
      "embusen": { "x": 0, "z": 1.5, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["openHandBlockL", "openHandBlockR"], "overrides": { "head": { "y": 0.7 } } },
        { "t": 0.3, "stance": "seiunchinDachi", "arms": ["blockDoubleLow"] },
        { "t": 0.6, "stance": "seiunchinDachi", "arms": ["haitoR", "guardChestL"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["grabPullR", "nukiteL"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0, "z": 2.6, "facing": 3.1416 }, "text": "Third angle of the same scenario; consistent structure." },
      "transition": { "known": true, "source": "Seiunchin.md step 3" } },
    { "id": 4, "label": "Shift back to cat — catch and backfist the leg", "coachCall": "Shift back. Catch. Backfist the leg.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 1.3, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "catR", "arms": ["grabPullL", "chamberR"] },
        { "t": 0.55, "stance": "catR", "arms": ["grabPullL", "hammerfistR"] },
        { "t": 1, "stance": "catR", "arms": ["shutoMidL", "hammerfistR"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": 0, "z": 2.4, "facing": 3.1416 }, "text": "Catch the low attack, strike the limb, set the reinforced control." },
      "transition": { "known": true, "source": "Seiunchin.md step 4" } },
    { "id": 5, "label": "Slide forward — reinforced punch, rising elbow", "coachCall": "Drive in. Reinforced punch. Grab the head. Rising elbow.", "beats": 4, "kiai": false,
      "embusen": { "x": 0, "z": 1.8, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["reinforcedBlockR"] },
        { "t": 0.4, "stance": "seisanDachiR", "arms": ["punchMidR", "guardChestL"] },
        { "t": 0.7, "stance": "seisanDachiR", "arms": ["grabPullL", "elbowRisingR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["grabPullL", "elbowRisingR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 0, "z": 2.9, "facing": 3.1416 }, "text": "Drive in, clinch behind the head, elbow to chin or jaw." },
      "transition": { "known": true, "source": "Seiunchin.md step 5" } },
    { "id": 6, "label": "45° right entry — reinforced block, low backfist, low block", "coachCall": "Angle right. Reinforced block. Low backfist. Slide back. Low block.", "beats": 5, "kiai": false,
      "embusen": { "x": -0.5, "z": 2.3, "facing": -0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["reinforcedBlockR"] },
        { "t": 0.4, "stance": "seiunchinDachi", "arms": ["hammerfistL", "guardChestR"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": -1.3, "z": 3.1, "facing": 2.3562 }, "text": "Angle entry to the flank; backfist to groin or thigh, then cover low." },
      "transition": { "known": true, "source": "Seiunchin.md step 6" } },
    { "id": 7, "label": "45° left entry — mirror", "coachCall": "Angle left. Reinforced block. Low backfist. Slide back. Low block.", "beats": 5, "kiai": false,
      "embusen": { "x": 0.5, "z": 2.3, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["reinforcedBlockL"] },
        { "t": 0.4, "stance": "seiunchinDachi", "arms": ["hammerfistL", "guardChestR"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowL", "guardChestR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchL", "attackerFrom": { "x": 1.3, "z": 3.1, "facing": 3.927 }, "text": "Same diagonal concept on the opposite side." },
      "transition": { "known": true, "source": "Seiunchin.md step 7" } },
    { "id": 8, "label": "Step back — archer block against kick", "coachCall": "Step back. Archer block.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 1.8, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["archerBlockR"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": 0, "z": 2.9, "facing": 3.1416 }, "text": "Front-kick defense with high cover; clear with the left." },
      "transition": { "known": true, "source": "Seiunchin.md step 8" } },
    { "id": 9, "label": "Step back — mirror archer block", "coachCall": "Step back. Archer block.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 1.3, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["archerBlockL"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickL", "attackerFrom": { "x": 0, "z": 2.4, "facing": 3.1416 }, "text": "Mirror front-kick defense." },
      "transition": { "known": true, "source": "Seiunchin.md step 9" } },
    { "id": 10, "label": "Step forward — block, break, backfist", "coachCall": "Step in. Block. Break the arm. Backfist.", "beats": 4, "kiai": false,
      "embusen": { "x": 0, "z": 1.8, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["blockMidL", "chamberR"] },
        { "t": 0.4, "stance": "seisanDachiR", "arms": ["grabPullL", "shutoMidR"] },
        { "t": 0.75, "stance": "seisanDachiR", "arms": ["blockLowL", "backfistR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["blockLowL", "backfistR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 0, "z": 2.9, "facing": 3.1416 }, "text": "Arm break or clear, then high strike to nose or temple." },
      "transition": { "known": true, "source": "Seiunchin.md step 10" } },
    { "id": 11, "label": "Pivot to back corner — middle block, low block", "coachCall": "Pivot. Middle block. Low block.", "beats": 3, "kiai": false,
      "embusen": { "x": -0.7, "z": 1.2, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 0.5, "stance": "seisanDachiL", "arms": ["blockMidL", "guardChestR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["blockMidL", "blockLowR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": -1.5, "z": 0.4, "facing": 0.7854 }, "text": "High and low coverage against an angled attack; the pivot drives from the hips." },
      "transition": { "known": true, "source": "Seiunchin.md step 11" } },
    { "id": 12, "label": "Slide in — uppercut, shote, backfist, low strike", "coachCall": "Slide in. Uppercut. Shote. Backfist. Strike low.", "beats": 5, "kiai": false,
      "embusen": { "x": -1.1, "z": 0.8, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["uppercutL", "shoteR"] },
        { "t": 0.4, "stance": "seiunchinDachi", "arms": ["guardChestL", "backfistR"] },
        { "t": 0.75, "stance": "seiunchinDachi", "arms": ["guardChestL", "hammerfistR"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["guardChestL", "chamberR"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": -1.9, "z": 0.0, "facing": 0.7854 }, "text": "Inside clinch: lift the body, check, head shot, then groin or leg finish." },
      "transition": { "known": true, "source": "Seiunchin.md step 12" } },
    { "id": 13, "label": "Slide back — low block", "coachCall": "Slide back. Low block.", "beats": 2, "kiai": false,
      "embusen": { "x": -0.7, "z": 1.2, "facing": 3.927 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowR", "guardChestL"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "Seiunchin.md step 13" } },
    { "id": 14, "label": "Pivot 180° — middle block, low block", "coachCall": "Pivot. Middle block. Low block.", "beats": 3, "kiai": false,
      "embusen": { "x": 0.7, "z": 1.2, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiL", "arms": ["guardBoth"] },
        { "t": 0.5, "stance": "seisanDachiL", "arms": ["blockMidL", "guardChestR"] },
        { "t": 1, "stance": "seisanDachiL", "arms": ["blockMidL", "blockLowR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 1.5, "z": 2.0, "facing": 3.927 }, "text": "Mirror of step 11 to the opposite corner." },
      "transition": { "known": true, "source": "Seiunchin.md step 14" } },
    { "id": 15, "label": "Slide in — mirror uppercut sequence", "coachCall": "Slide in. Uppercut. Shote. Backfist. Strike low.", "beats": 5, "kiai": false,
      "embusen": { "x": 1.1, "z": 1.6, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["uppercutR", "shoteL"] },
        { "t": 0.4, "stance": "seiunchinDachi", "arms": ["guardChestR", "backfistL"] },
        { "t": 0.75, "stance": "seiunchinDachi", "arms": ["guardChestR", "hammerfistL"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["guardChestR", "chamberL"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 1.9, "z": 2.4, "facing": 3.927 }, "text": "Mirror of step 12: same close-range idea on the opposite side." },
      "transition": { "known": true, "source": "Seiunchin.md step 15" } },
    { "id": 16, "label": "Slide back — low block", "coachCall": "Slide back. Low block.", "beats": 2, "kiai": false,
      "embusen": { "x": 0.7, "z": 1.2, "facing": 0.7854 },
      "keyframes": [
        { "t": 0, "stance": "seiunchinDachi", "arms": ["guardBoth"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowL", "guardChestR"] }
      ],
      "bunkai": { "known": false },
      "transition": { "known": true, "source": "Seiunchin.md step 16" } },
    { "id": 17, "label": "Left back to cat — left elbow strike", "coachCall": "Back to cat. Elbow strike.", "beats": 3, "kiai": false,
      "embusen": { "x": 0, "z": 0.9, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "catL", "arms": ["guardBoth"] },
        { "t": 1, "stance": "catL", "arms": ["elbowStrikeL", "guardChestR"] }
      ],
      "bunkai": { "known": true, "attack": "grabLapel", "attackerFrom": { "x": 0, "z": 1.9, "facing": 3.1416 }, "text": "Close-range elbow to jaw or ribs from the clinch." },
      "transition": { "known": true, "source": "Seiunchin.md step 17" } },
    { "id": 18, "label": "Right back to cat — elbow, then twist-punch block", "coachCall": "Back to cat. Elbow. Twist punch to the kick.", "beats": 4, "kiai": false,
      "embusen": { "x": 0, "z": 0.6, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "catR", "arms": ["guardBoth"] },
        { "t": 0.45, "stance": "catR", "arms": ["elbowStrikeR", "guardChestL"] },
        { "t": 1, "stance": "seiunchinDachi", "arms": ["blockLowR", "guardChestL"] }
      ],
      "bunkai": { "known": true, "attack": "frontKickR", "attackerFrom": { "x": 0, "z": 1.7, "facing": 3.1416 }, "text": "Elbow, then twist-punch block to shin or ankle of the incoming kick." },
      "transition": { "known": true, "source": "Seiunchin.md step 18" } },
    { "id": 19, "label": "Step forward — push-down block, backfist, KIAI", "coachCall": "Step in. Push down. Backfist. Kiai!", "beats": 4, "kiai": true,
      "embusen": { "x": 0, "z": 1.1, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "seisanDachiR", "arms": ["guardBoth"] },
        { "t": 0.45, "stance": "seisanDachiR", "arms": ["shutoLowL", "chamberR"] },
        { "t": 0.75, "stance": "seisanDachiR", "arms": ["shutoLowL", "backfistR"] },
        { "t": 1, "stance": "seisanDachiR", "arms": ["shutoLowL", "backfistR"] }
      ],
      "bunkai": { "known": true, "attack": "steppingPunchR", "attackerFrom": { "x": 0, "z": 2.2, "facing": 3.1416 }, "text": "Final decisive counter: press the punch down and backfist the face." },
      "transition": { "known": true, "source": "Seiunchin.md step 19; kiai confirmed by isshinryukarate.net" } },
    { "id": 20, "label": "Back to cat — break grab, settle, close", "coachCall": "Elbows down. Break the grab. Settle. Bow.", "beats": 5, "kiai": false,
      "embusen": { "x": 0, "z": 0.7, "facing": 0 },
      "keyframes": [
        { "t": 0, "stance": "catL", "arms": ["guardBoth"] },
        { "t": 0.35, "stance": "catL", "arms": ["doubleFistDown"] },
        { "t": 0.7, "stance": "feetTogether", "arms": ["armsDown"] },
        { "t": 1, "stance": "bow" }
      ],
      "bunkai": { "known": true, "attack": "grabRear", "attackerFrom": { "x": 0, "z": -0.4, "facing": 0 }, "text": "Bring the elbows down to break a body grab, drop the heel, finish." },
      "transition": { "known": true, "source": "Seiunchin.md step 20" } }
  ]
}
